APP_NAME=VELIS
APP_ENV=production
DEBUG=False
SECRET_KEY=velis-production-secret-key-change-this-in-real-deployment
JWT_SECRET_KEY=velis-jwt-production-key-change-this-in-real-deployment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql://velis_user:velis_password@postgres:5432/velis_db
REDIS_URL=redis://redis:6379
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads
AUDIO_DIR=audio
HUGGINGFACE_MODEL=google/flan-t5-base
WHISPER_MODEL=base
TTS_ENGINE=gtts
TTS_LANGUAGE=en
