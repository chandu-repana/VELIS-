# Application
APP_NAME=VELIS
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database
POSTGRES_USER=velis_user
POSTGRES_PASSWORD=velis_password
POSTGRES_DB=velis_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://velis_user:velis_password@localhost:5432/velis_db

# JWT Auth
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# File Upload
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=uploads/

# AI Models
WHISPER_MODEL=base
HF_MODEL_NAME=google/flan-t5-base

# CORS
FRONTEND_URL=http://localhost:3000